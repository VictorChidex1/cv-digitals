rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. GLOBAL DEFAULT DENY: Absolute lockdown. Nobody can read, write, or delete.
    match /{document=**} {
      allow read, write: if false;
    }
    
    // 2. CONTACT TERMINAL ENDPOINT: Strict Schema Validation
    match /contacts/{contactId} {
      
      // PUBLIC BLACKOUT: Nobody reads, updates, or lists CV Digitals proprietary lead data.
      allow read, update, delete: if false;
      
      // CREATION PROTOCOL: Only extremely strict structured payloads pass the firewall.
      allow create: if
        // A. Payload Key Isolation (No extra injected fields)
        request.resource.data.keys().hasAll(['name', 'email', 'objective', 'scope', 'budget', 'timestamp', 'status']) &&
        request.resource.data.keys().hasOnly(['name', 'email', 'objective', 'scope', 'budget', 'timestamp', 'status']) &&
        
        // B. Name String Constraints (Prevent bloated name fields)
        request.resource.data.name is string &&
        request.resource.data.name.size() >= 2 &&
        request.resource.data.name.size() <= 100 &&
        
        // C. Email Format Structural Validation
        request.resource.data.email is string &&
        request.resource.data.email.size() <= 200 &&
        request.resource.data.email.matches('^[^@]+@[^@]+\\.[a-zA-Z]{2,}$') &&
        
        // D. Objective Payload Constraints (Prevent Database memory floods)
        request.resource.data.objective is string &&
        request.resource.data.objective.size() >= 10 &&
        request.resource.data.objective.size() <= 4000 &&
        
        // E. Strict Enum Logic Locking (Hackers cannot inject fake parameters)
        request.resource.data.scope in ['software', 'audio'] &&
        request.resource.data.budget in ['startup', 'enterprise', 'global'] &&
        
        // F. Backend Server System Checks
        request.resource.data.status == 'pending_review' &&
        request.resource.data.timestamp == request.time;
    }
  }
}
